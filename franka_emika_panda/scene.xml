<mujoco model="panda scene">
  <include file="panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="cube_mat" rgba="1 0.2 0.2 1"/>
  </asset>

<worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="table" pos="0.4 0.3 0.15">
      <geom size="0.15 0.15 0.15" type="box" rgba="0.4 0.4 0.4 1"/>
    </body>

    <body name="target" pos="-0.4 -0.3 0.05">
      <geom size="0.08 0.08 0.05" type="box" rgba="0.93 0.75 0.02 1"/>
    </body>

    <body name="cube1" pos="0.3 0.4 0.45">
      <freejoint/> 
      <geom rgba="0.2 0.2 1 1" type="box" size="0.02 0.02 0.02" mass="0.05" condim="4" friction="2.0 0.1 0.002" 
            priority="1" solimp="0.99 0.99 0.01" solref="0.01 1"/>
    </body>

    <body name="cube2" pos="0.45 0.3 0.45">
      <freejoint/>
      <geom rgba="0.2 1 0.2 1" type="box" size="0.02 0.08 0.02" mass="0.05" condim="4" friction="2.0 0.1 0.002" 
            priority="1" solimp="0.99 0.99 0.01" solref="0.01 1"/>
    </body>
    <body name="cube3" pos="0.35 0.2 0.45">
      <freejoint/>
      <geom rgba="1 0.2 0.2 1" type="box" size="0.05 0.02 0.02" mass="0.05" condim="4" friction="2.0 0.1 0.002" 
            priority="1" solimp="0.99 0.99 0.01" solref="0.01 1"/>
    </body>
  </worldbody>
</mujoco>
